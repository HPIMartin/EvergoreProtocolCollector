{
	"name": "Evergore Protocol Collector (Java 17 / Maven)",
	"image": "mcr.microsoft.com/devcontainers/base:bookworm",
	"features": {
		"ghcr.io/devcontainers/features/java:1": {
			"version": "17",
			"installMaven": "true",
			"installGradle": "false"
		}
	},
	"postCreateCommand": "mvn -B -q dependency:go-offline --fail-never || true",
	"customizations": {
		"vscode": {
			"extensions": [
				"Anthropic.claude-code",
				"vscjava.vscode-java-pack"
			],
			"settings": {
				"java.configuration.updateBuildConfiguration": "automatic",
				"files.eol": "\n"
			}
		}
	}
}
