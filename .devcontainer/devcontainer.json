{
	"name": "Evergore Protocol Collector (Java 25 / Gradle)",
	"image": "mcr.microsoft.com/devcontainers/base:bookworm",
	"features": {
		"ghcr.io/devcontainers/features/java:1": {
			"version": "25",
			"installMaven": "false",
			"installGradle": "false"
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		}
	},
	"containerEnv": {
		"CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
	},
	"mounts": [
		"source=${localWorkspaceFolder}/.devcontainer/.claude-home,target=/home/vscode/.claude,type=bind"
	],
	"postCreateCommand": "git config core.hooksPath hooks; ./gradlew --no-daemon build -x test || true",
	"customizations": {
		"vscode": {
			"extensions": [
				"Anthropic.claude-code",
				"vscjava.vscode-java-pack",
				"shengchen.vscode-checkstyle"
			],
			"settings": {
				"java.configuration.updateBuildConfiguration": "automatic",
				"files.eol": "\n"
			}
		}
	}
}
